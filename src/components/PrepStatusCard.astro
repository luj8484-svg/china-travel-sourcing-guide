---
interface Item {
  label: string;
  status?: string;
  done?: boolean;
}

interface Props {
  title?: string;
  subtitle?: string;
  progress?: number;
  items?: Item[];
  footer?: string;
  tone?: 'blue' | 'orange';
}

const {
  title = 'Prep Status Overview',
  subtitle = 'Visa Check',
  progress = 50,
  items = [],
  footer,
  tone = 'blue'
} = Astro.props;
const safeProgress = Math.max(0, Math.min(100, progress));
---

<div class="prep-card">
  <div class="prep-card-header">
    <div class="prep-card-title-row">
      <h3>{title}</h3>
      <span class="status-label">{safeProgress}%</span>
    </div>
    <div class="progress-label-row">
      <span>{subtitle}</span>
      <span>{safeProgress === 100 ? 'Complete' : 'In Progress'}</span>
    </div>
    <div class={`progress ${tone === 'orange' ? 'orange' : ''}`} aria-label={`${safeProgress}% complete`}>
      <span style={`width: ${safeProgress}%`}></span>
    </div>
  </div>
  <ul class="prep-card-list">
    {items.map((item) => (
      <li class={`check-item ${item.done ? 'done' : ''}`}>
        <span class={`check-dot ${item.done ? 'done' : ''}`} aria-hidden="true">{item.done ? '✓' : ''}</span>
        <span class="check-text">
          <strong>{item.label}</strong>
          {item.status && <span>{item.status}</span>}
        </span>
      </li>
    ))}
  </ul>
  {footer && <div class="progress-label-row" style="padding: 0 22px 18px;"><span>{footer}</span></div>}
</div>
