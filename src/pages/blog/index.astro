---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ArticleCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const motifByCategory = {
  'china-travel': 'map',
  'canton-fair': 'badge',
  'china-sourcing': 'supplier',
  tools: 'checklist'
} as const;
---

<BaseLayout
  title="Blog"
  description="English China travel, Canton Fair, wholesale market, and sourcing guides for international visitors and buyers."
  canonical="/blog/"
>
  <section class="content-page">
    <div class="page-header">
      <span class="badge">Blog</span>
      <h1>Practical China travel and sourcing guides.</h1>
      <p>Guides for visitors, Canton Fair buyers, and small business importers preparing for China.</p>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <ArticleCard
          href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category.replace('-', ' ')}
          updated={post.data.updatedDate ? post.data.updatedDate.toLocaleDateString('en', { month: 'short', year: 'numeric' }) : post.data.pubDate.toLocaleDateString('en', { month: 'short', year: 'numeric' })}
          motif={post.data.coverMotif ?? motifByCategory[post.data.category as keyof typeof motifByCategory]}
          image={post.data.coverImage}
        />
      ))}
    </div>
  </section>
</BaseLayout>
