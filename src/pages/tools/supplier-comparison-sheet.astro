---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolLayout from '@layouts/ToolLayout.astro';
import PrepStatusCard from '@components/PrepStatusCard.astro';
import ToolCard from '@components/ToolCard.astro';
import WarningBox from '@components/WarningBox.astro';
import SidebarCard from '@components/SidebarCard.astro';
---

<BaseLayout
  title="Supplier Comparison Sheet"
  description="A simple supplier comparison template for China sourcing beginners comparing MOQ, price, samples, trade terms, lead time, and communication."
  canonical="/tools/supplier-comparison-sheet/"
>
  <ToolLayout>
    <div slot="hero" class="hub-hero">
      <div class="page-header">
        <span class="badge">Sourcing Tool</span>
        <h1>Supplier Comparison Sheet</h1>
        <p>Compare MOQ, price, samples, lead time, trade terms, payment terms, certificates, packaging, and communication quality side by side.</p>
        <div class="inline-actions">
          <a class="button" href="#fields">Review comparison fields</a>
        </div>
      </div>
      <PrepStatusCard
        title="Supplier Comparison Score"
        subtitle="Required fields prepared"
        progress={44}
        tone="orange"
        items={[
          { label: 'Product specification written', done: true },
          { label: 'Target quantity defined' },
          { label: 'Sample criteria prepared' }
        ]}
      />
    </div>

    <section id="fields" class="checklist-panel">
      <div class="checklist-heading">
        <div>
          <span class="status-label">Comparison fields</span>
          <h2>Record the same details for every supplier</h2>
        </div>
      </div>
      <table class="simple-table">
        <thead>
          <tr>
            <th>Field</th>
            <th>What to record</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Supplier name</td><td>Company name, contact person, booth number, or platform profile.</td></tr>
          <tr><td>Product match</td><td>How closely the product fits your specification.</td></tr>
          <tr><td>MOQ and price</td><td>Minimum order quantity, unit price, and quantity breaks.</td></tr>
          <tr><td>Sample details</td><td>Sample cost, sample lead time, and shipping method.</td></tr>
          <tr><td>Trade terms</td><td>EXW, FOB, included packaging, and any excluded costs.</td></tr>
          <tr><td>Quality notes</td><td>Certificates, test reports, inspection options, and known risks.</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>Copyable Supplier Note</h2>
      <div class="copy-box">
        <pre>Supplier comparison:
- Supplier:
- Contact:
- Product:
- MOQ:
- Unit price:
- Sample cost and lead time:
- Production lead time:
- Trade terms:
- Packaging:
- Certificates or tests:
- Communication notes:
- Next action:</pre>
      </div>
    </section>

    <section class="section">
      <h2>Related Sourcing Resources</h2>
      <div class="grid-3">
        <ToolCard icon="Guide" title="Supplier Comparison Guide" description="Compare product fit, MOQ, price, samples, lead time, terms, and communication before ordering samples." href="/blog/how-to-compare-chinese-suppliers-before-sample-order/" />
        <ToolCard icon="Sample" title="Sample Request Guide" description="Confirm sample cost, lead time, shipping, specifications, quality checks, and follow-up before a bulk order." href="/blog/how-to-request-samples-from-chinese-suppliers/" />
        <ToolCard icon="QC" title="Quality Control Checklist" description="Confirm samples, specs, packaging, inspection, defect handling, and written order details." href="/blog/chinese-supplier-quality-control-checklist-before-bulk-order/" />
        <ToolCard icon="MOQ" title="MOQ and Price Negotiation Guide" description="Negotiate MOQ, price breaks, trial orders, packaging costs, samples, and written terms." href="/blog/how-to-negotiate-moq-price-chinese-suppliers/" />
        <ToolCard icon="Order" title="First Order Confirmation Guide" description="Confirm specs, samples, MOQ, price, payment terms, packaging, QC, lead time, and written details." href="/blog/what-to-confirm-before-first-order-chinese-supplier/" />
        <ToolCard icon="Fair" title="Supplier Questions at Canton Fair" description="Use consistent supplier questions for MOQ, samples, pricing, lead time, payment terms, QC, and follow-up." href="/blog/supplier-questions-to-ask-at-canton-fair/" />
      </div>
    </section>

    <SidebarCard slot="sidebar" title="Buyer tip">
      <p>Compare quotes only after you confirm the same product specification, packaging, trade terms, and lead time.</p>
    </SidebarCard>
    <WarningBox slot="sidebar" title="Do not compare price alone">
      <p>A lower unit price can hide higher sample costs, longer lead time, weak packaging, or missing quality documents.</p>
    </WarningBox>
  </ToolLayout>
</BaseLayout>
