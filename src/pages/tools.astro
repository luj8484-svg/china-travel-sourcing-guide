---
import BaseLayout from '@layouts/BaseLayout.astro';
import HubLayout from '@layouts/HubLayout.astro';
import HubHero from '@components/HubHero.astro';
import ToolCard from '@components/ToolCard.astro';
import CTASection from '@components/CTASection.astro';
---

<BaseLayout
  title="Tools"
  description="Simple China travel, Canton Fair, and sourcing checklists for visitors and overseas buyers preparing for China."
  canonical="/tools/"
>
  <HubLayout>
    <HubHero
      slot="hero"
      eyebrow="Tools"
      title="Checklists and templates for planning your China trip"
      description="Use these simple tools to prepare your China trip, trade fair visit, or supplier comparison process without relying on memory."
      primaryHref="/tools/china-trip-checklist/"
      primaryLabel="Start travel checklist"
      secondaryHref="/tools/supplier-comparison-sheet/"
      secondaryLabel="Open supplier sheet"
      statusTitle="Resource Center"
      progress={66}
    />

    <section class="section">
      <div class="tool-grid">
        <ToolCard icon="Trip" title="China Trip Checklist" description="Documents, payment apps, internet, hotel, transport, and daily route planning." href="/tools/china-trip-checklist/" label="Open checklist" />
        <ToolCard icon="Fair" title="Canton Fair Buyer Checklist" description="Badge, phase selection, supplier questions, booth notes, samples, and post-fair follow-up." href="/tools/canton-fair-buyer-checklist/" label="Open buyer checklist" />
        <ToolCard icon="Sheet" title="Supplier Comparison Sheet" description="Compare MOQ, price, lead time, trade terms, sample cost, payment terms, and communication quality." href="/tools/supplier-comparison-sheet/" label="Open comparison sheet" />
      </div>
    </section>
  </HubLayout>

  <CTASection
    title="Save These Checklists Before You Travel"
    description="Start with the travel checklist, then use the fair and sourcing tools if your trip includes buyer meetings."
    buttonLabel="Open Travel Checklist"
    buttonHref="/tools/china-trip-checklist/"
  />
</BaseLayout>
