---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const { eyebrow = 'Free Resource', title, description, buttonLabel = 'Open checklist', buttonHref = '/tools/china-trip-checklist/' } = Astro.props;
---

<section class="cta-section">
  <div class="section">
    <span class="badge">{eyebrow}</span>
    <h2>{title}</h2>
    <p>{description}</p>
    <form class="email-form" action={buttonHref}>
      <input type="email" name="email" placeholder="Enter your email address" aria-label="Email address" />
      <button class="button" type="submit">{buttonLabel}</button>
    </form>
    <p class="status-label">No spam. Useful China prep resources only.</p>
  </div>
</section>
