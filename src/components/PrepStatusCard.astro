---
interface Item {
  label: string;
  status?: string;
  done?: boolean;
}

interface Props {
  title?: string;
  subtitle?: string;
  progress?: number;
  items?: Item[];
  footer?: string;
  tone?: 'green' | 'orange' | 'blue';
  syncKey?: string;
}

const {
  title = 'Prep Status Overview',
  subtitle = 'Visa Check',
  progress = 50,
  items = [],
  footer,
  tone = 'green',
  syncKey
} = Astro.props;
const safeProgress = Math.max(0, Math.min(100, progress));
const progressStatus = safeProgress === 0 ? 'Not started' : safeProgress === 100 ? 'Complete' : 'In progress';
---

<div class={`prep-card tone-${tone}`} data-progress-card={syncKey}>
  <div class="prep-card-header">
    <div class="prep-card-title-row">
      <h3>{title}</h3>
      <span class="status-label"><span data-status-card-progress-value>{safeProgress}</span>%</span>
    </div>
    <div class="progress-label-row">
      <span>{subtitle}</span>
      <span data-status-card-status>{progressStatus}</span>
    </div>
    <div class={`progress ${tone === 'orange' ? 'orange' : ''}`} aria-label={`${safeProgress}% complete`}>
      <span data-status-card-progress-bar style={`width: ${safeProgress}%`}></span>
    </div>
  </div>
  <ul class="prep-card-list">
    {items.map((item) => (
      <li class={`check-item ${item.done ? 'done' : ''}`}>
        <span class={`check-dot ${item.done ? 'done' : ''}`} aria-hidden="true">{item.done ? 'OK' : ''}</span>
        <span class="check-text">
          <strong>{item.label}</strong>
          {item.status && <span>{item.status}</span>}
        </span>
      </li>
    ))}
  </ul>
  {footer && <div class="progress-label-row prep-card-footer"><span>{footer}</span></div>}
</div>
