---
import BaseLayout from '@layouts/BaseLayout.astro';
import HubLayout from '@layouts/HubLayout.astro';
import HubHero from '@components/HubHero.astro';
import PainPointCard from '@components/PainPointCard.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import ChecklistBlock from '@components/ChecklistBlock.astro';
import WarningBox from '@components/WarningBox.astro';
import Faq from '@components/Faq.astro';

const faqs = [
  { question: 'Do I need a Chinese bank account to use Alipay or WeChat Pay?', answer: 'Most first-time visitors can try linking an international card, but you should test the app before departure and keep a backup card or cash.' },
  { question: 'Is cash still accepted in China?', answer: 'Cash is legal tender, but many daily situations are much easier with mobile payment. Treat cash as a backup, not the primary plan.' },
  { question: 'Which is better: eSIM or VPN?', answer: 'An eSIM or roaming plan helps you get online. A VPN may be useful depending on the apps and sites you need. Confirm your setup before flying.' },
  { question: 'Can I use Uber or Lyft in China?', answer: 'No. Plan to use local ride-hailing options, hotel help, metro, taxis, or a prearranged transfer depending on the city.' },
  { question: 'Will my WhatsApp work in China?', answer: 'Access can be unreliable. Prepare backup contact methods and confirm your internet setup before arrival.' }
];

---

<BaseLayout
  title="First-Time China Travel Guide"
  description="A practical China travel hub for first-time visitors covering payment apps, internet access, hotels, addresses, transport, and itinerary planning."
  canonical="/china-travel/"
>
  <HubLayout>
    <HubHero
      slot="hero"
      eyebrow="Travel Setup"
      title="China Travel Setup Guide for First-Time Visitors"
      description="Prepare your phone, payment apps, internet, maps, transport, hotel address, and backup plan before you land in China."
      primaryHref="/tools/china-trip-checklist/"
      primaryLabel="Start the Travel Setup Checklist"
      secondaryHref="/tools/china-trip-checklist/"
      secondaryLabel="Use Payment Readiness Checker"
    />

    <section class="section" aria-labelledby="who-title">
      <div class="center-heading">
        <h2 id="who-title">Who This Hub Is For</h2>
        <p>Tailored advice for different types of travelers to China.</p>
      </div>
      <div class="grid-4">
        <PainPointCard icon="1st" title="First-Time Visitors" description="Step-by-step guidance on setting up payments, navigating the firewall, and basic etiquette." />
        <PainPointCard icon="Biz" title="Business Travelers" description="Streamlined setups for quick trips, focusing on reliable communication and efficient transport." />
        <PainPointCard icon="CF" title="Canton Fair Visitors" description="Specific preparation for Guangzhou, registration, local transport, and fair logistics." />
        <PainPointCard icon="Buy" title="Sourcing Buyers" description="In-depth guides on visiting factories, negotiating with suppliers, and managing logistics." />
      </div>
    </section>

    <section class="section" aria-labelledby="start-title">
      <div class="section-heading">
        <div>
          <h2 id="start-title">Start Here Before You Land</h2>
          <p>Follow these guides in order to prepare payment, internet, addresses, hotel location, transport, and your final checklist.</p>
        </div>
        <a class="button secondary" href="/blog/">View all guides</a>
      </div>
      <div class="article-grid">
        <ArticleCard href="/blog/china-payment-apps-for-foreign-visitors/" title="1. Payment Setup" description="Prepare Alipay, WeChat Pay, backup cards, emergency cash, internet access, and payment testing before arrival." category="Step 1" motif="checklist" />
        <ArticleCard href="/blog/china-esim-internet-access-guide/" title="2. Internet Access" description="Compare roaming, eSIM, local SIM, Wi-Fi, app access, and backup internet planning before arrival." category="Step 2" motif="map" />
        <ArticleCard href="/blog/how-to-save-use-chinese-addresses-china/" title="3. Chinese Addresses" description="Save hotel, venue, supplier, and daily destination details in Chinese before you travel." category="Step 3" motif="map" />
        <ArticleCard href="/blog/china-hotel-location-guide-first-time-visitors/" title="4. Hotel Location" description="Choose a practical hotel area with metro or taxi access, Chinese address clarity, food nearby, and easier arrival logistics." category="Step 4" motif="hotel" />
        <ArticleCard href="/blog/how-to-get-around-in-china/" title="5. Getting Around" description="Prepare metro routes, taxis, maps, ride-hailing backup, Chinese addresses, payment, and internet before arrival." category="Step 5" motif="map" />
        <ArticleCard href="/blog/china-travel-checklist-first-time-visitors/" title="6. Final Travel Checklist" description="Review payment, internet, hotel address, transport, daily route, and offline documents before you fly." category="Step 6" motif="checklist" />
      </div>
    </section>

    <section class="section" aria-labelledby="checklist-title">
      <div class="content-grid">
        <div>
          <span class="eyebrow">Your China Travel Setup Checklist</span>
          <h2 id="checklist-title">Follow these 8 critical steps before you board your flight.</h2>
          <p>Use this as a practical readiness list before arrival, not a generic packing checklist.</p>
          <div class="inline-actions">
            <a class="button" href="/tools/china-trip-checklist/">Open online checklist</a>
            <a class="button secondary" href="/free-checklist/" data-track-event="checklist_cta_click" data-cta-location="china_travel_hub" data-cta-label="Get Free Checklist" data-cta-destination="/free-checklist/">Request free checklist</a>
          </div>
        </div>
        <ChecklistBlock
          title="Before You Land"
          progress={62}
          items={[
            { label: 'Install and verify Alipay / WeChat', description: 'Download both apps, register with your phone number, and connect a card.', done: true },
            { label: 'Link international credit cards', description: 'Add Visa, Mastercard, or JCB where available and test a small payment.', done: true },
            { label: 'Purchase an eSIM or configure VPN', description: 'Pick an internet setup that supports your required apps.' },
            { label: 'Download offline maps or local map app', description: 'Save hotel and daily destination names in Chinese.' },
            { label: 'Set up ride-hailing', description: 'Confirm how you will handle taxis or ride-hailing from arrival.' },
            { label: 'Save hotel address in Chinese', description: 'Keep screenshots for drivers and check-in.' },
            { label: 'Download translation apps', description: 'Prepare offline translation for menus and transport.' },
            { label: 'Inform your bank', description: 'Reduce the chance of payment blocks during the trip.' }
          ]}
        />
      </div>
    </section>

    <div class="band">
      <section class="section" aria-labelledby="tools-title">
        <div class="center-heading">
          <h2 id="tools-title">Tools for Travel Setup</h2>
          <p>Interactive tools to speed up your preparation.</p>
        </div>
        <div class="grid-4">
          <ToolCard icon="Pay" title="Payment Readiness Checker" description="Verify your Alipay and WeChat setup." href="/tools/china-trip-checklist/" />
          <ToolCard icon="App" title="App Checklist" description="Make sure you have every essential app downloaded." href="/tools/china-trip-checklist/" />
          <ToolCard icon="Visa" title="Visa-Free Checker" description="Check if your passport qualifies for visa-free entry." href="/tools/china-trip-checklist/" />
          <ToolCard icon="SIM" title="eSIM/VPN Prep" description="Compare internet setups for your trip." href="/tools/china-trip-checklist/" />
        </div>
      </section>
    </div>

    <section class="section" aria-labelledby="mistakes-title">
      <div class="center-heading">
        <h2 id="mistakes-title">Common Mistakes First-Time Visitors Make</h2>
        <p>Avoid these pitfalls that can ruin your first few days in China.</p>
      </div>
      <div class="grid-3">
        <WarningBox title="Waiting To Download Apps"><p>Do not wait until you land to download VPNs, payment apps, or map tools. Some setup steps are harder inside China.</p></WarningBox>
        <WarningBox title="Relying Only on Google Maps"><p>Google Maps is highly inaccurate in some locations. Prepare local alternatives and Chinese names.</p></WarningBox>
        <WarningBox title="Not Informing Banks"><p>If your card is blocked for suspicious overseas activity, it can be painful to resolve while traveling.</p></WarningBox>
      </div>
      <Faq title="Travel Setup FAQs" items={faqs} />
    </section>
  </HubLayout>
</BaseLayout>
