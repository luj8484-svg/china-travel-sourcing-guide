---
interface Props {
  image?: string;
  alt?: string;
  motif?: 'travel' | 'canton-fair' | 'sourcing' | 'tools' | 'map' | 'checklist' | 'badge' | 'hotel' | 'supplier';
  label?: string;
  compact?: boolean;
}

const {
  image,
  alt = '',
  motif = 'tools',
  label = 'China Buyer Prep guide visual',
  compact = false
} = Astro.props;

type Motif = NonNullable<Props['motif']>;
type CoverVariant = 'travel' | 'canton-fair' | 'sourcing' | 'tools';

const motifMap: Record<Motif, CoverVariant> = {
  travel: 'travel',
  'canton-fair': 'canton-fair',
  sourcing: 'sourcing',
  tools: 'tools',
  map: 'travel',
  badge: 'canton-fair',
  supplier: 'sourcing',
  checklist: 'tools',
  hotel: 'travel'
};

const normalizedMotif = motifMap[motif];
---

{
  image ? (
    <figure class={`article-cover has-image ${compact ? 'compact' : ''}`}>
      <img src={image} alt={alt} loading={compact ? 'lazy' : 'eager'} decoding="async" />
    </figure>
  ) : (
    <div
      class={`article-cover placeholder ${normalizedMotif} ${compact ? 'compact' : ''}`}
      role="img"
      aria-label={label}
    >
      <div class="cover-paper" aria-hidden="true"></div>
      <div class="cover-motif" aria-hidden="true">
        {normalizedMotif === 'travel' && (
          <svg viewBox="0 0 320 180">
            <path d="M44 122 C88 48, 132 138, 174 82 S250 54, 282 116" />
            <circle cx="44" cy="122" r="10" />
            <circle cx="174" cy="82" r="10" />
            <path d="M96 42 h48 M94 62 h30 M214 120 h46" />
            <path d="M238 36 l18 18 l-18 18 l-18 -18z" />
          </svg>
        )}
        {normalizedMotif === 'canton-fair' && (
          <svg viewBox="0 0 320 180">
            <rect x="86" y="30" width="148" height="120" rx="14" />
            <path d="M126 30 v-16 h68 v16" />
            <circle cx="134" cy="84" r="20" />
            <path d="M172 70 h42 M172 94 h42 M112 124 h96" />
          </svg>
        )}
        {normalizedMotif === 'sourcing' && (
          <svg viewBox="0 0 320 180">
            <rect x="56" y="42" width="208" height="104" rx="12" />
            <path d="M56 76 h208 M126 42 v104 M194 42 v104" />
            <path d="M82 103 h24 M150 103 h24 M218 103 h22 M82 126 h24 M150 126 h24 M218 126 h22" />
          </svg>
        )}
        {normalizedMotif === 'tools' && (
          <svg viewBox="0 0 320 180">
            <rect x="72" y="34" width="176" height="118" rx="14" />
            <path d="M104 72 l13 13 l28 -33" />
            <path d="M104 112 l13 13 l28 -33" />
            <path d="M166 70 h54 M166 112 h54" />
          </svg>
        )}
      </div>
      {!compact && <span class="cover-label">{label}</span>}
    </div>
  )
}
