---
import ArticleCover from './ArticleCover.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  category?: string;
  readTime?: string;
  updated?: string;
  image?: string;
  motif?: 'travel' | 'canton-fair' | 'sourcing' | 'tools' | 'map' | 'checklist' | 'badge' | 'hotel' | 'supplier';
}

const {
  href,
  title,
  description,
  category = 'Guide',
  readTime = '6 min read',
  updated,
  image,
  motif = 'tools'
} = Astro.props;

const displayCategory = category
  .split(/[\s-]+/)
  .filter(Boolean)
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');
---

<a class="article-card" href={href}>
  <ArticleCover image={image} alt={title} motif={motif} label={displayCategory} compact />
  <div class="article-card-body">
    <span class="card-kicker">{displayCategory}</span>
    <h2>{title}</h2>
    <p>{description}</p>
    <div class="article-meta-row">
      <span>{readTime}</span>
      {updated && <span>Updated {updated}</span>}
    </div>
  </div>
</a>
