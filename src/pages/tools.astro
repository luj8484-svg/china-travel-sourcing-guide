---
import BaseLayout from '@layouts/BaseLayout.astro';
import HubLayout from '@layouts/HubLayout.astro';
import HubHero from '@components/HubHero.astro';
import ToolCard from '@components/ToolCard.astro';
---

<BaseLayout
  title="Tools"
  description="Simple China travel, Canton Fair, and sourcing checklists for visitors and overseas buyers preparing for China."
  canonical="/tools/"
>
  <HubLayout>
    <HubHero
      slot="hero"
      eyebrow="Tools"
      title="Checklists and templates for planning your China trip"
      description="Use these simple tools to prepare your China trip, trade fair visit, or supplier comparison process without relying on memory."
      primaryHref="/tools/china-trip-checklist/"
      primaryLabel="Start travel checklist"
      secondaryHref="/tools/supplier-comparison-sheet/"
      secondaryLabel="Open supplier sheet"
      statusTitle="Resource Center"
      progress={66}
    />

    <section class="section">
      <div class="editorial-note" style="margin-bottom: 24px;">
        <span class="eyebrow">Resource center</span>
        <h2>Choose the tool that matches the decision in front of you.</h2>
        <p>Use these pages as preparation worksheets. They are intentionally static, copyable, and fast so the important details stay visible to search engines and readers.</p>
      </div>
      <div class="tool-grid">
        <ToolCard icon="Trip" title="China Trip Checklist" description="Best for first-time travel setup: documents, payment apps, internet, hotel, transport, and daily route planning." href="/tools/china-trip-checklist/" label="Open checklist" />
        <ToolCard icon="Fair" title="Canton Fair Buyer Checklist" description="Best for Canton Fair preparation: badge, phase selection, supplier questions, booth notes, and post-fair follow-up." href="/tools/canton-fair-buyer-checklist/" label="Open buyer checklist" />
        <ToolCard icon="Sourcing" title="China Sourcing Checklist" description="Best for small importers preparing supplier comparison, samples, quality control, first order details, trade terms, freight questions, and landed cost." href="/tools/china-sourcing-checklist/" label="Open sourcing checklist" />
        <ToolCard icon="Sheet" title="Supplier Comparison Sheet" description="Best for supplier comparison: MOQ, price, lead time, trade terms, sample cost, payment terms, and communication quality." href="/tools/supplier-comparison-sheet/" label="Open comparison sheet" />
      </div>
    </section>
  </HubLayout>
</BaseLayout>
