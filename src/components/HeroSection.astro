---
import PrepStatusCard from './PrepStatusCard.astro';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  primaryTarget?: string;
  primaryRel?: string;
  primaryTrackEvent?: string;
  primaryCtaLocation?: string;
  primaryCtaLabel?: string;
  primaryCtaDestination?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  secondaryTarget?: string;
  secondaryRel?: string;
  secondaryTrackEvent?: string;
  secondaryCtaLocation?: string;
  secondaryCtaLabel?: string;
  secondaryCtaDestination?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryHref,
  primaryLabel,
  primaryTarget,
  primaryRel,
  primaryTrackEvent,
  primaryCtaLocation,
  primaryCtaLabel,
  primaryCtaDestination,
  secondaryHref,
  secondaryLabel,
  secondaryTarget,
  secondaryRel,
  secondaryTrackEvent,
  secondaryCtaLocation,
  secondaryCtaLabel,
  secondaryCtaDestination
} = Astro.props;
---

<section class="hero">
  <div class="hero-copy">
    <span class="badge">{eyebrow}</span>
    <h1>{title}</h1>
    <p>{description}</p>
    <div class="hero-actions">
      <a class="button" href={primaryHref} target={primaryTarget} rel={primaryRel} data-track-event={primaryTrackEvent} data-cta-location={primaryCtaLocation} data-cta-label={primaryCtaLabel} data-cta-destination={primaryCtaDestination}>{primaryLabel}</a>
      {secondaryHref && secondaryLabel && <a class="button secondary" href={secondaryHref} target={secondaryTarget} rel={secondaryRel} data-track-event={secondaryTrackEvent} data-cta-location={secondaryCtaLocation} data-cta-label={secondaryCtaLabel} data-cta-destination={secondaryCtaDestination}>{secondaryLabel}</a>}
    </div>
  </div>
  <slot name="visual">
    <PrepStatusCard
      progress={50}
      items={[
        { label: 'Payment Ready', status: 'Success', done: true },
        { label: 'Apps Installed', status: 'Pending' },
        { label: 'Canton Fair Plan', status: 'Ready', done: true },
        { label: 'Supplier Questions Prepared', status: '5/10' }
      ]}
    />
  </slot>
</section>
