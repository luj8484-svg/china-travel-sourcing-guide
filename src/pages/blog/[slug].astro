---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import ArticleCover from '@components/ArticleCover.astro';
import ArticleCard from '@components/ArticleCard.astro';
import Faq from '@components/Faq.astro';
import SidebarCard from '@components/SidebarCard.astro';
import WarningBox from '@components/WarningBox.astro';
import OfficialSourceNote from '@components/OfficialSourceNote.astro';
import CTASection from '@components/CTASection.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: any) => ({
    params: { slug: post.slug ?? post.id.replace(/\.(md|mdx)$/, '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const rendered = await render(post);
const { Content, headings = [] } = rendered;
const allPosts = await getCollection('blog');
const slug = post.slug ?? post.id.replace(/\.(md|mdx)$/, '');
const canonical = post.data.canonical ?? `/blog/${slug}/`;
const articleUrl = new URL(canonical, Astro.site ?? Astro.url.origin).href;
const updatedDate = post.data.updatedDate ?? post.data.pubDate;
const words = String(post.body ?? post.data.description).trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(3, Math.ceil(words / 180));
const categoryLabel = post.data.category.replace('-', ' ');

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: updatedDate.toISOString(),
  mainEntityOfPage: articleUrl,
  image: new URL(post.data.ogImage, Astro.site ?? Astro.url.origin).href,
  author: {
    '@type': 'Organization',
    name: 'China Buyer Prep'
  },
  publisher: {
    '@type': 'Organization',
    name: 'China Buyer Prep'
  }
};
const faqSchema = post.data.faqs
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faqs.map((item: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer
        }
      }))
    }
  : null;
const schema = faqSchema ? [articleSchema, faqSchema] : [articleSchema];
const checklistCtaByCategory = {
  'china-travel': {
    heading: 'Use the travel checklist',
    body: 'Confirm payment, internet, hotel address, transport, and daily route before departure.',
    href: '/tools/china-trip-checklist/',
    label: 'Open checklist',
    quick: 'Set up payment, internet access, Chinese hotel addresses, transport apps, and a realistic daily route before you land.',
    avoid: 'Do not wait until arrival to test payment, maps, translation, or your hotel address.'
  },
  'canton-fair': {
    heading: 'Use the buyer checklist',
    body: 'Confirm your phase, hotel area, buyer badge, supplier questions, and follow-up process.',
    href: '/tools/canton-fair-buyer-checklist/',
    label: 'Open buyer checklist',
    quick: 'Confirm your fair phase, hotel area, buyer badge, supplier questions, and follow-up process before booking too much of the trip.',
    avoid: 'Do not choose flights or hotels before checking the fair phase and your daily route to Pazhou.'
  },
  'china-sourcing': {
    heading: 'Use the supplier sheet',
    body: 'Track MOQ, price, sample cost, lead time, terms, and communication quality.',
    href: '/tools/supplier-comparison-sheet/',
    label: 'Open comparison sheet',
    quick: 'Compare suppliers using the same fields: specification, MOQ, price, sample cost, lead time, terms, and communication.',
    avoid: 'Do not choose a supplier from unit price alone before checking samples, trade terms, packaging, and quality risks.'
  },
  tools: {
    heading: 'Use the tools',
    body: 'Review the related checklist or template before you make travel, fair, or supplier decisions.',
    href: '/tools/',
    label: 'Open tools',
    quick: 'Use a checklist or template before making decisions that affect your trip or supplier follow-up.',
    avoid: 'Do not rely on memory for details you need to compare later.'
  }
};
const checklistCta = checklistCtaByCategory[post.data.category as keyof typeof checklistCtaByCategory];
const motifByCategory = {
  'china-travel': 'map',
  'canton-fair': slug.includes('stay-guangzhou') ? 'hotel' : 'badge',
  'china-sourcing': 'supplier',
  tools: 'checklist'
} as const;
const coverMotif =
  post.data.coverMotif ?? motifByCategory[post.data.category as keyof typeof motifByCategory] ?? 'checklist';
const relatedPosts = allPosts
  .filter((item: any) => (item.slug ?? item.id.replace(/\.(md|mdx)$/, '')) !== slug)
  .slice(0, 3);
---

<BaseLayout
  title={post.data.metaTitle ?? post.data.title}
  description={post.data.description}
  canonical={canonical}
  ogImage={post.data.ogImage}
  type="article"
  schema={schema}
>
  <ArticleLayout>
    <header slot="header" class="article-header">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/blog/">Blog</a>
        <span>›</span>
        <span>{categoryLabel}</span>
      </nav>
      <span class="badge">{categoryLabel}</span>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="article-top-meta">
        <span>Updated {updatedDate.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        <span>{readingMinutes} min read</span>
        <span class="badge success">Verified / reviewed</span>
      </div>
    </header>

    <div class="article-summary">
      <ArticleCover
        image={post.data.coverImage}
        alt={post.data.coverAlt ?? post.data.title}
        motif={coverMotif}
        label={post.data.title}
      />
      <div class="summary-box" style="margin-top: 20px;">
        <span class="card-kicker">Summary</span>
        <p>{post.data.description}</p>
      </div>
      <div class="callout quick-answer">
        <strong>Key takeaways</strong>
        <p>{checklistCta.quick}</p>
      </div>
    </div>

    <Content />

    <WarningBox title="Common mistake">
      <p>{checklistCta.avoid}</p>
    </WarningBox>

    <OfficialSourceNote>
      Always confirm current app, visa, payment, hotel, fair, or supplier requirements with official sources before making final travel or purchasing decisions.
    </OfficialSourceNote>

    <Faq title="Frequently Asked Questions" items={post.data.faqs} />

    {relatedPosts.length > 0 && (
      <section class="faq-section" aria-labelledby="related-title">
        <h2 id="related-title">Related guides</h2>
        <div class="article-grid">
          {relatedPosts.map((item: any) => (
            <ArticleCard
              href={`/blog/${item.slug ?? item.id.replace(/\.(md|mdx)$/, '')}/`}
              title={item.data.title}
              description={item.data.description}
              category={item.data.category.replace('-', ' ')}
              motif={item.data.coverMotif ?? motifByCategory[item.data.category as keyof typeof motifByCategory]}
              image={item.data.coverImage}
            />
          ))}
        </div>
      </section>
    )}

    <Fragment slot="toc">
      {headings.length > 0 ? (
        <ul class="toc-list">
          {headings.filter((heading: any) => heading.depth === 2).slice(0, 8).map((heading: any) => (
            <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
          ))}
        </ul>
      ) : (
        <p>Read the summary, checklist, and FAQ sections.</p>
      )}
    </Fragment>

    <SidebarCard slot="sidebar" title={checklistCta.heading} description={checklistCta.body} href={checklistCta.href} label={checklistCta.label} />
    <SidebarCard slot="sidebar" title="Review status">
      <p>This guide is reviewed for practical usefulness and updated when the site content changes.</p>
      <span class="badge success">Verified / reviewed</span>
    </SidebarCard>
  </ArticleLayout>

  <CTASection
    title="Get the Free China Prep Checklist"
    description="Use a focused checklist before your trip, fair visit, or supplier follow-up."
    buttonLabel="Open Checklist"
    buttonHref={checklistCta.href}
  />
</BaseLayout>
