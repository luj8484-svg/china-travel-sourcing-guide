---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolLayout from '@layouts/ToolLayout.astro';
import PrepStatusCard from '@components/PrepStatusCard.astro';
import ChecklistBlock from '@components/ChecklistBlock.astro';
import ToolCard from '@components/ToolCard.astro';
import WarningBox from '@components/WarningBox.astro';
import SidebarCard from '@components/SidebarCard.astro';
---

<BaseLayout
  title="Canton Fair Buyer Checklist"
  description="A practical Canton Fair buyer checklist for overseas visitors preparing phases, registration, hotel location, booth visits, and supplier follow-up."
  canonical="/tools/canton-fair-buyer-checklist/"
>
  <ToolLayout>
    <div slot="hero" class="hub-hero">
      <div class="page-header">
        <span class="badge">Buyer Tool</span>
        <h1>Canton Fair Buyer Checklist</h1>
        <p>Confirm your phase, buyer badge, hotel area, booth plan, supplier questions, sample process, and post-fair follow-up before arriving in Guangzhou.</p>
        <div class="inline-actions">
          <a class="button" href="#checklist">Start buyer checklist</a>
        </div>
      </div>
      <PrepStatusCard
        title="Fair Readiness Score"
        subtitle="Phase and badge setup"
        progress={55}
        tone="orange"
        items={[
          { label: 'Product phase checked', done: true },
          { label: 'Buyer badge prepared' },
          { label: 'Hotel area confirmed' }
        ]}
      />
    </div>

    <ChecklistBlock
      title="Canton Fair Buyer Checklist"
      progress={55}
      items={[
        { label: 'Confirm the correct fair phase', description: 'Match product category to Phase 1, 2, or 3.', done: true },
        { label: 'Prepare buyer registration details', description: 'Passport, company information, and business cards.' },
        { label: 'Book a practical hotel area', description: 'Prioritize route to Pazhou and metro access.' },
        { label: 'Build booth visit priorities', description: 'Know which categories and halls matter most.' },
        { label: 'Prepare supplier questions', description: 'MOQ, price, samples, lead time, payment terms, and certificates.' },
        { label: 'Create follow-up workflow', description: 'Request quotes and samples soon after the fair.' }
      ]}
    />

    <section class="section">
      <h2>Buyer Meeting Recommendations</h2>
      <div class="grid-3">
        <ToolCard icon="Q" title="Use the Same Questions" description="Ask each supplier the same core questions so comparison is possible." href="/tools/supplier-comparison-sheet/" />
        <ToolCard icon="Note" title="Write Booth Notes Fast" description="Record details immediately after each meaningful conversation." href="/blog/canton-fair-first-time-buyer-guide/" />
        <ToolCard icon="Sample" title="Decide Sample Next Steps" description="Mark who should receive a sample request or quote follow-up." href="/tools/supplier-comparison-sheet/" />
      </div>
    </section>

    <SidebarCard slot="sidebar" title="Fair day habit">
      <p>Write notes after every booth visit. Supplier details blur together quickly in a large exhibition hall.</p>
    </SidebarCard>
    <WarningBox slot="sidebar" title="Check your phase first">
      <p>Do not book flights or hotels until the correct product phase is confirmed.</p>
    </WarningBox>
  </ToolLayout>
</BaseLayout>
