---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tools"
  description="Simple China travel and sourcing tools, checklists, and templates for foreign visitors and international buyers."
  canonical="/tools/"
>
  <section class="content-page">
    <div class="page-header">
      <span class="eyebrow">Tools</span>
      <h1>Checklists and lightweight tools.</h1>
      <p>Start with simple templates that support SEO content and can later become paid downloads or lead magnets.</p>
    </div>
    <div class="tool-grid">
      <div class="tool-card">
        <h2>China Trip Checklist</h2>
        <p>Documents, payment apps, internet, hotel, transport, and daily route planning.</p>
      </div>
      <div class="tool-card">
        <h2>Canton Fair Buyer Checklist</h2>
        <p>Badge, phase selection, supplier questions, booth notes, samples, and post-fair follow-up.</p>
      </div>
      <div class="tool-card">
        <h2>Supplier Comparison Sheet</h2>
        <p>Compare MOQ, price, lead time, trade terms, sample cost, payment terms, and communication quality.</p>
      </div>
    </div>
  </section>
</BaseLayout>
