---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import BuyerPrepPanel from '@components/BuyerPrepPanel.astro';
import CategoryPathCard from '@components/CategoryPathCard.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const motifByCategory = {
  'china-travel': 'travel',
  'canton-fair': 'canton-fair',
  'china-sourcing': 'sourcing',
  tools: 'tools'
} as const;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Buyer Prep',
    url: Astro.site?.href ?? 'https://www.chinabuyerprep.com/',
    inLanguage: 'en',
    description:
      'Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers.'
  }
];
---

<BaseLayout
  title="China Buyer Prep"
  description="Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers."
  schema={schema}
>
  <HeroSection
    eyebrow="Practical China preparation for first-time buyers"
    title="Arrive in China with the basics already handled."
    description="China Buyer Prep helps first-time visitors, Canton Fair buyers, and sourcing beginners prepare payment, internet, hotels, fair logistics, supplier questions, and follow-up notes before the trip starts."
    primaryHref="/china-travel/"
    primaryLabel="Start with travel setup"
    secondaryHref="/tools/"
    secondaryLabel="Open preparation tools"
  >
    <BuyerPrepPanel slot="visual" />
  </HeroSection>

  <section class="section" aria-labelledby="path-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Choose the right starting point</span>
        <h2 id="path-title">Three practical paths, one preparation system.</h2>
      </div>
      <p>Each path is built around what can actually slow you down in China: payment, movement, fair logistics, supplier comparison, and follow-up.</p>
    </div>
    <div class="grid-3">
      <CategoryPathCard
        icon="01"
        title="Travel setup"
        description="Payment apps, internet access, Chinese hotel addresses, transport basics, and a realistic first-day plan."
        href="/china-travel/"
        label="Prepare arrival"
      />
      <CategoryPathCard
        icon="02"
        title="Canton Fair prep"
        description="Fair phase, buyer badge, hotel area, booth notes, supplier questions, and post-fair follow-up."
        href="/canton-fair/"
        label="Plan fair visit"
      />
      <CategoryPathCard
        icon="03"
        title="Supplier sourcing"
        description="Product specs, supplier comparison, samples, trade terms, quality checks, and shipment readiness."
        href="/china-sourcing/"
        label="Compare suppliers"
      />
    </div>
  </section>

  <div class="band">
    <section class="section" aria-labelledby="tools-title">
      <div class="home-feature-grid">
        <div class="home-feature-lead">
          <span class="status-label">Resource center</span>
          <h2 id="tools-title">Use the tools when a decision needs a checklist.</h2>
          <p>These are not calculators for show. They are simple preparation sheets for the moments where memory is unreliable: payment setup, fair planning, and supplier comparison.</p>
          <div class="inline-actions">
            <a class="button" href="/tools/">View all tools</a>
          </div>
        </div>
        <div class="grid-3">
          <ToolCard icon="Pay" title="China Trip Checklist" description="Best for first-time travel setup: payment, internet, hotel address, maps, and route planning." href="/tools/china-trip-checklist/" label="Open checklist" />
          <ToolCard icon="Fair" title="Canton Fair Buyer Checklist" description="Best for Canton Fair preparation: phase, badge, hotel area, booth notes, and follow-up." href="/tools/canton-fair-buyer-checklist/" label="Open fair tool" />
          <ToolCard icon="Sheet" title="Supplier Comparison Sheet" description="Best for supplier comparison: MOQ, samples, lead time, terms, and quality notes." href="/tools/supplier-comparison-sheet/" label="Open sheet" />
        </div>
      </div>
    </section>
  </div>

  <section class="section" aria-labelledby="guides-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Latest preparation guides</span>
        <h2 id="guides-title">Start with the guides buyers actually need before arrival.</h2>
      </div>
      <a class="button secondary" href="/blog/">View all guides</a>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <ArticleCard
          href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category.replace('-', ' ')}
          updated={post.data.updatedDate ? post.data.updatedDate.toLocaleDateString('en', { month: 'short', year: 'numeric' }) : post.data.pubDate.toLocaleDateString('en', { month: 'short', year: 'numeric' })}
          motif={post.data.coverMotif ?? motifByCategory[post.data.category as keyof typeof motifByCategory]}
          image={post.data.coverImage}
        />
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="editorial-title">
    <div class="editorial-note">
      <span class="eyebrow">Editorial promise</span>
      <h2 id="editorial-title">Practical, specific, and kept lightweight.</h2>
      <p>China Buyer Prep stays focused on preparation details that affect real trips: what to install, what to save, what to ask, and what to compare. No heavy app shell, no generic travel inspiration wall, and no external image dependencies.</p>
    </div>
  </section>
</BaseLayout>
