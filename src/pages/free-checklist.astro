---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import ToolCard from '@components/ToolCard.astro';
import WarningBox from '@components/WarningBox.astro';

const checklistFormUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSebO1lQAN1H0HHNXqSNxu98wLHfp8hATqe1CqDVptvbFrikBA/viewform';
---

<BaseLayout
  title="Get the Right China Buyer Prep Checklist"
  description="Choose the China Buyer Prep checklist for a first China trip, Canton Fair visit, or China sourcing plan."
  canonical="/free-checklist/"
>
  <HeroSection
    eyebrow="Checklist routing"
    title="Get the Right China Buyer Prep Checklist"
    description="Choose the checklist that matches what you are preparing for: a first China trip, Canton Fair visit, or China sourcing plan."
    primaryHref={checklistFormUrl}
    primaryLabel="Request the checklist"
    primaryTarget="_blank"
    primaryRel="noopener noreferrer"
    secondaryHref="/"
    secondaryLabel="Browse preparation guides"
  />

  <section class="section" aria-labelledby="choose-title">
    <div class="summary-box">
      <span class="card-kicker">Choose your path</span>
      <h2 id="choose-title">China preparation depends on your trip goal.</h2>
      <p>China preparation is different depending on whether you are planning your first trip, visiting the Canton Fair, or preparing to source products from Chinese suppliers. Use this page to choose the most relevant checklist and guide path.</p>
    </div>
  </section>

  <section class="section" aria-labelledby="paths-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Checklist paths</span>
        <h2 id="paths-title">Start with the checklist that matches your situation.</h2>
      </div>
      <a class="button secondary" href="/tools/">View all online tools</a>
    </div>
    <div class="grid-3">
      <article class="tool-card">
        <span class="icon-tile" aria-hidden="true">Trip</span>
        <h2>First China Trip Checklist</h2>
        <p>For first-time visitors preparing payment apps, internet access, hotel location, Chinese addresses, and getting around in China.</p>
        <a class="button" href="/tools/china-trip-checklist/">View China Travel Checklist</a>
        <ul>
          <li><a href="/china-travel/">China Travel Hub</a></li>
          <li><a href="/blog/china-payment-apps-for-foreign-visitors/">China Payment Apps Guide</a></li>
          <li><a href="/blog/china-esim-internet-access-guide/">China eSIM and Internet Access Guide</a></li>
        </ul>
      </article>

      <article class="tool-card">
        <span class="icon-tile" aria-hidden="true">Fair</span>
        <h2>Canton Fair Buyer Checklist</h2>
        <p>For overseas buyers preparing Canton Fair registration, buyer badge basics, phases, supplier questions, hotel area, and fair planning.</p>
        <a class="button" href="/tools/canton-fair-buyer-checklist/">View Canton Fair Checklist</a>
        <ul>
          <li><a href="/canton-fair/">Canton Fair Hub</a></li>
          <li><a href="/blog/canton-fair-first-time-buyer-guide/">Canton Fair First-Time Buyer Guide</a></li>
          <li><a href="/blog/supplier-questions-to-ask-at-canton-fair/">Supplier Questions to Ask at the Canton Fair</a></li>
        </ul>
      </article>

      <article class="tool-card">
        <span class="icon-tile" aria-hidden="true">Source</span>
        <h2>China Sourcing Checklist</h2>
        <p>For small importers preparing supplier comparison, samples, quality control, MOQ, trade terms, freight forwarder questions, and landed cost.</p>
        <a class="button" href="/tools/china-sourcing-checklist/">View China Sourcing Checklist</a>
        <ul>
          <li><a href="/china-sourcing/">China Sourcing Hub</a></li>
          <li><a href="/tools/supplier-comparison-sheet/">Supplier Comparison Sheet</a></li>
          <li><a href="/blog/how-to-estimate-landed-cost-importing-from-china/">Landed Cost Guide</a></li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="unsure-title">
    <div class="content-grid">
      <div>
        <span class="eyebrow">Not sure which checklist you need?</span>
        <h2 id="unsure-title">Tell us what you are preparing for.</h2>
        <p>If you are not sure where to start, tell us what you are preparing for and we will point you to the most relevant checklist or guide.</p>
        <div class="inline-actions">
          <a class="button" href={checklistFormUrl} target="_blank" rel="noopener noreferrer">Request the checklist</a>
          <a class="button secondary" href="/tools/">Browse online tools</a>
        </div>
      </div>
      <WarningBox title="Practical preparation guidance">
        <p>Requirements can change. Confirm current details with official sources or service providers when needed. This is practical preparation guidance, not legal, tax, customs, or official event advice.</p>
      </WarningBox>
    </div>
  </section>

  <section class="section" aria-labelledby="also-use-title">
    <div class="center-heading">
      <h2 id="also-use-title">Useful preparation hubs</h2>
      <p>Each hub gives you a more detailed guide path after you choose the right checklist.</p>
    </div>
    <div class="grid-3">
      <ToolCard icon="Travel" title="First China trip" description="Prepare payment, internet, Chinese addresses, hotel location, transport, and daily routes." href="/china-travel/" label="Open travel hub" />
      <ToolCard icon="Fair" title="Canton Fair preparation" description="Prepare registration, phases, hotel area, booth notes, supplier questions, and follow-up." href="/canton-fair/" label="Open fair hub" />
      <ToolCard icon="Source" title="China sourcing preparation" description="Prepare supplier comparison, samples, first order details, trade terms, freight questions, and landed cost." href="/china-sourcing/" label="Open sourcing hub" />
    </div>
  </section>

  <section class="cta-section">
    <div class="section">
      <h2>Prepare before you travel, visit suppliers, or place your first order</h2>
      <p>Use the right checklist before you arrive in China, attend the Canton Fair, compare suppliers, or pay for a first order.</p>
      <div class="cta-actions">
        <a class="button" href={checklistFormUrl} target="_blank" rel="noopener noreferrer">Request the checklist</a>
        <a class="button secondary" href="/tools/">Browse preparation tools</a>
      </div>
    </div>
  </section>
</BaseLayout>
