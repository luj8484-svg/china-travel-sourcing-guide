---
import BaseLayout from '@layouts/BaseLayout.astro';
import HubLayout from '@layouts/HubLayout.astro';
import HubHero from '@components/HubHero.astro';
import PainPointCard from '@components/PainPointCard.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import ChecklistBlock from '@components/ChecklistBlock.astro';
import WarningBox from '@components/WarningBox.astro';
import Faq from '@components/Faq.astro';

const faqs = [
  { question: 'What should I prepare before contacting suppliers?', answer: 'Prepare product specifications, target quantity, packaging needs, sample criteria, and questions about trade terms.' },
  { question: 'Is lowest unit price the best supplier choice?', answer: 'No. Compare MOQ, samples, lead time, trade terms, communication, packaging, and quality risk.' },
  { question: 'Should I visit factories?', answer: 'Factory visits can help for higher-risk orders, but prepare a clear checklist and follow-up process before you go.' }
];

const checklistFormUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSebO1lQAN1H0HHNXqSNxu98wLHfp8hATqe1CqDVptvbFrikBA/viewform';
---

<BaseLayout
  title="China Sourcing Guide"
  description="A practical China sourcing hub for small business importers covering product specs, supplier comparison, samples, payment terms, QC, and shipment preparation."
  canonical="/china-sourcing/"
>
  <HubLayout>
    <HubHero
      slot="hero"
      eyebrow="Sourcing Guides"
      title="Find better suppliers and avoid beginner sourcing mistakes"
      description="Define your product clearly, compare suppliers on the same terms, test samples, and plan quality checks before shipment."
      primaryHref="/tools/supplier-comparison-sheet/"
      primaryLabel="Open comparison sheet"
      secondaryHref="/blog/china-sourcing-checklist-small-business/"
      secondaryLabel="Read sourcing checklist"
      statusTitle="Supplier Prep Status"
      progress={48}
    />

    <section class="section">
      <div class="center-heading">
        <h2>Who This Hub Is For</h2>
        <p>For buyers who want a cleaner supplier process before visiting markets, factories, or trade shows.</p>
      </div>
      <div class="grid-4">
        <PainPointCard icon="Spec" title="New Importers" description="Turn rough product ideas into requirements suppliers can quote accurately." />
        <PainPointCard icon="Shop" title="Online Sellers" description="Compare supplier terms before choosing samples or production partners." />
        <PainPointCard icon="MOQ" title="Small Buyers" description="Understand MOQ, sample cost, trade terms, and realistic lead times." />
        <PainPointCard icon="QC" title="Quality-Focused Teams" description="Plan samples, inspection, packaging, and shipment checks earlier." />
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <h2>Start Here Before You Order</h2>
          <p>Follow the sourcing path from supplier comparison to samples, quality checks, MOQ and price, then first order confirmation.</p>
        </div>
        <a class="button secondary" href="/blog/">View all guides</a>
      </div>
      <div class="article-grid">
        <ArticleCard href="/blog/how-to-compare-chinese-suppliers-before-sample-order/" title="1. Compare Chinese Suppliers" description="Compare product fit, MOQ, unit price, samples, lead time, terms, quality checks, and communication before ordering samples." category="Step 1" motif="supplier" />
        <ArticleCard href="/blog/exw-fob-cif-ddp-china-sourcing/" title="EXW, FOB, CIF, and DDP Explained" description="Understand quote scope, named place, shipping responsibility, documents, risk, and what to confirm before payment." category="Trade Terms" motif="supplier" />
        <ArticleCard href="/blog/how-to-request-samples-from-chinese-suppliers/" title="2. Request Samples" description="Confirm sample cost, lead time, shipping, specs, packaging, and follow-up before a bulk order." category="Step 2" motif="supplier" />
        <ArticleCard href="/blog/chinese-supplier-quality-control-checklist-before-bulk-order/" title="3. Check Quality Control" description="Confirm samples, specs, packaging, inspection, defect handling, and written details before placing a bulk order." category="Step 3" motif="supplier" />
        <ArticleCard href="/blog/how-to-negotiate-moq-price-chinese-suppliers/" title="4. Negotiate MOQ and Price" description="Ask for price breaks, trial order options, sample cost clarity, packaging costs, payment terms, and written confirmation." category="Step 4" motif="supplier" />
        <ArticleCard href="/blog/what-to-confirm-before-first-order-chinese-supplier/" title="5. Confirm Your First Order" description="Confirm product specs, samples, MOQ, price, payment terms, packaging, QC, lead time, and written details before payment." category="Step 5" motif="supplier" />
        <ArticleCard href="/blog/china-sourcing-checklist-small-business/" title="China Sourcing Checklist for Small Business Importers" description="Product specs, suppliers, samples, payment terms, QC, and shipment prep." category="Sourcing" motif="supplier" />
        <ArticleCard href="/tools/supplier-comparison-sheet/" title="Supplier Comparison Sheet" description="Track MOQ, price, sample cost, lead time, terms, and communication quality." category="Tool" motif="checklist" />
        <ArticleCard href="/blog/canton-fair-first-time-buyer-guide/" title="Use Canton Fair Conversations for Supplier Follow-Up" description="Convert booth visits into structured quotes and sample requests." category="Canton Fair" motif="badge" />
      </div>
    </section>

    <section class="section">
      <div class="content-grid">
        <div>
          <span class="eyebrow">Supplier Comparison Checklist</span>
          <h2>Compare suppliers on the same fields before choosing.</h2>
          <p>Use one template for requirements, quotes, samples, terms, and quality risk.</p>
          <div class="inline-actions">
            <a class="button" href="/tools/supplier-comparison-sheet/">Open comparison sheet</a>
            <a class="button secondary" href={checklistFormUrl} target="_blank" rel="noopener noreferrer">Request free checklist</a>
          </div>
        </div>
        <ChecklistBlock
          title="Sourcing Prep Progress"
          progress={42}
          items={[
            { label: 'Write product specification', description: 'Size, material, packaging, target market, and key tolerances.', done: true },
            { label: 'Prepare target quantity and budget', description: 'Make MOQ conversations more realistic.', done: true },
            { label: 'Compare trade terms', description: 'EXW, FOB, packaging, and excluded costs.' },
            { label: 'Request samples clearly', description: 'Ask for sample lead time, cost, and approval criteria.' },
            { label: 'Check quality documentation', description: 'Certificates, test reports, and inspection options.' },
            { label: 'Plan shipment questions', description: 'Lead time, cartons, weights, and export readiness.' }
          ]}
        />
      </div>
    </section>

    <div class="band">
      <section class="section">
        <div class="center-heading">
          <h2>Related Tools</h2>
        </div>
        <div class="grid-3">
          <ToolCard icon="Sheet" title="Supplier Comparison Sheet" description="Compare multiple suppliers using consistent criteria." href="/tools/supplier-comparison-sheet/" />
          <ToolCard icon="CF" title="Canton Fair Buyer Checklist" description="Prepare supplier questions and booth notes for fair visits." href="/tools/canton-fair-buyer-checklist/" />
          <ToolCard icon="Trip" title="China Trip Checklist" description="Prepare travel basics before supplier visits." href="/tools/china-trip-checklist/" />
        </div>
      </section>
    </div>

    <section class="section">
      <div class="center-heading">
        <h2>Common Sourcing Mistakes</h2>
      </div>
      <div class="grid-3">
        <WarningBox title="Asking For Quotes Too Early"><p>Without clear specs, supplier quotes are hard to compare and may hide important assumptions.</p></WarningBox>
        <WarningBox title="Choosing By Unit Price Alone"><p>The lowest unit price may exclude packaging, testing, trade terms, or quality safeguards.</p></WarningBox>
        <WarningBox title="Skipping Sample Notes"><p>Sample approval should be written down so production can be checked against the same standard.</p></WarningBox>
      </div>
      <Faq title="Sourcing FAQs" items={faqs} />
    </section>
  </HubLayout>
</BaseLayout>
