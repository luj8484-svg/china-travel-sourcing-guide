---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import EntryCard from '@components/EntryCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Travel & Sourcing Guide',
    url: Astro.site?.href ?? 'https://chinatravelsourcingguide.com/',
    inLanguage: 'en',
    description:
      'English guides for first-time China travelers, Canton Fair visitors, and international sourcing buyers.'
  }
];
---

<BaseLayout
  title="China Travel & Sourcing Guide"
  description="Practical English guides for first-time China visitors, Canton Fair attendees, and small business importers sourcing from China."
  schema={schema}
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Practical China guides in English</span>
      <h1>Plan your China trip, trade fair visit, or sourcing project with less guesswork.</h1>
      <p>
        Clear, checklist-based guidance for first-time China visitors, Canton Fair attendees, and small business
        importers who need to prepare before they arrive.
      </p>
      <div class="hero-actions">
        <a class="button" href="/china-travel/">Plan a China trip</a>
        <a class="button secondary" href="/canton-fair/">Prepare for Canton Fair</a>
      </div>
    </div>
    <div class="visual-panel" aria-label="China trip planning workflow">
      <div class="route-map">
        <div class="route-step">
          <span>1</span>
          <div>
            <strong>Prepare</strong>
            <p>Payment apps, internet access, Chinese addresses, hotel location, and daily transport routes.</p>
          </div>
        </div>
        <div class="route-step">
          <span>2</span>
          <div>
            <strong>Visit</strong>
            <p>Canton Fair phases, buyer badge basics, booth notes, supplier questions, and follow-up tasks.</p>
          </div>
        </div>
        <div class="route-step">
          <span>3</span>
          <div>
            <strong>Follow up</strong>
            <p>Product specifications, supplier comparison, samples, payment terms, QC, and shipment preparation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="start-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Start here</span>
        <h2 id="start-title">Choose the path that matches your goal.</h2>
      </div>
      <p>Start with the guide that matches your trip goal, then use the related checklists and articles to prepare step by step.</p>
    </div>
    <div class="entry-grid">
      <EntryCard
        href="/china-travel/"
        eyebrow="First-time China visitors"
        title="Travel Basics"
        description="Set up payment apps, choose internet access, save Chinese addresses, pick better hotel areas, and plan daily routes."
        accent="travel"
      />
      <EntryCard
        href="/canton-fair/"
        eyebrow="Canton Fair attendees"
        title="Fair Preparation"
        description="Understand fair phases, prepare registration details, choose a practical hotel area, plan booth visits, and follow up with suppliers."
        accent="fair"
      />
      <EntryCard
        href="/china-sourcing/"
        eyebrow="Small business importers"
        title="Sourcing Basics"
        description="Define product requirements, compare suppliers, request samples, understand payment terms, and prepare for quality checks."
        accent="sourcing"
      />
    </div>
  </section>

  <section class="section" aria-labelledby="latest-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Latest guides</span>
        <h2 id="latest-title">Useful guides to read first.</h2>
      </div>
      <a class="button secondary" href="/blog/">View all posts</a>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <a class="article-card" href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <span class="article-meta">{post.data.category.replace('-', ' ')}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
