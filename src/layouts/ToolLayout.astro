---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<section class={`content-page ${className}`}>
  <slot name="hero" />
  <div class="tool-grid-shell">
    <div>
      <slot />
    </div>
    <aside class="sidebar">
      <slot name="sidebar" />
    </aside>
  </div>
</section>
