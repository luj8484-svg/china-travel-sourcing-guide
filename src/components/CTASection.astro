---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const { eyebrow = 'Free Resource', title, description, buttonLabel = 'Open checklist', buttonHref = '/tools/china-trip-checklist/' } = Astro.props;
---

<section class="cta-section">
  <div class="section">
    <span class="badge">{eyebrow}</span>
    <h2>{title}</h2>
    <p>{description}</p>
    <div class="cta-actions">
      <a class="button" href={buttonHref}>{buttonLabel}</a>
    </div>
  </div>
</section>
