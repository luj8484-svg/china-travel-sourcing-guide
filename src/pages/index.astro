---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import EntryCard from '@components/EntryCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Buyer Prep',
    url: Astro.site?.href ?? 'https://www.chinabuyerprep.com/',
    inLanguage: 'en',
    description:
      'Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers.'
  }
];
---

<BaseLayout
  title="China Buyer Prep"
  description="Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers."
  schema={schema}
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Practical preparation for China buyers</span>
      <h1>China travel, Canton Fair, and sourcing checklists for first-time overseas buyers.</h1>
      <p>
        China Buyer Prep helps first-time China visitors, Canton Fair attendees, and small business importers prepare
        the details that matter before they arrive.
      </p>
      <div class="hero-actions">
        <a class="button" href="/china-travel/">Plan a China trip</a>
        <a class="button secondary" href="/canton-fair/">Prepare for Canton Fair</a>
      </div>
    </div>
    <div class="visual-panel" aria-label="China buyer preparation preview">
      <div class="visual-stack">
        <div class="map-card" aria-hidden="true">
          <span class="card-kicker">Route plan</span>
          <div class="map-line"></div>
        </div>
        <div class="badge-card">
          <div>
            <span class="card-kicker">Canton Fair</span>
            <strong>Buyer badge and phase check</strong>
          </div>
          <span class="badge-token">CBP</span>
        </div>
        <div class="comparison-card">
          <span class="card-kicker">Supplier comparison</span>
          <strong>Compare the same details before choosing.</strong>
          <div class="comparison-row"><span>MOQ and sample cost</span><span class="comparison-bar"><span style="width: 72%"></span></span></div>
          <div class="comparison-row"><span>Lead time and terms</span><span class="comparison-bar"><span style="width: 56%"></span></span></div>
          <div class="comparison-row"><span>QC and shipment prep</span><span class="comparison-bar"><span style="width: 84%"></span></span></div>
        </div>
        <div class="route-map" aria-label="Preparation steps">
          <div class="route-step">
            <span>1</span>
            <div>
              <strong>Prepare</strong>
              <p>Payment apps, internet access, Chinese addresses, hotel location, and daily routes.</p>
            </div>
          </div>
          <div class="route-step">
            <span>2</span>
            <div>
              <strong>Visit</strong>
              <p>Fair phases, buyer badge basics, booth notes, and supplier questions.</p>
            </div>
          </div>
          <div class="route-step">
            <span>3</span>
            <div>
              <strong>Follow up</strong>
              <p>Specifications, samples, payment terms, quality checks, and shipment details.</p>
            </div>
          </div>
        </div>
        <div class="mini-card">
          <span class="card-kicker">Checklist</span>
          <div>
            <strong>Before you book</strong>
            <p>Confirm your goal, route, documents, supplier notes, and next action.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="start-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Start here</span>
        <h2 id="start-title">Choose the path that matches your goal.</h2>
      </div>
      <p>Start with the guide that matches your trip goal, then use the related checklists and articles to prepare step by step.</p>
    </div>
    <div class="entry-grid">
      <EntryCard
        href="/china-travel/"
        eyebrow="First-time China visitors"
        title="Travel Basics"
        description="Set up payment apps, choose internet access, save Chinese addresses, pick better hotel areas, and plan daily routes."
        accent="travel"
      />
      <EntryCard
        href="/canton-fair/"
        eyebrow="Canton Fair attendees"
        title="Fair Preparation"
        description="Understand fair phases, prepare registration details, choose a practical hotel area, plan booth visits, and follow up with suppliers."
        accent="fair"
      />
      <EntryCard
        href="/china-sourcing/"
        eyebrow="Small business importers"
        title="Sourcing Basics"
        description="Define product requirements, compare suppliers, request samples, understand payment terms, and prepare for quality checks."
        accent="sourcing"
      />
    </div>
  </section>

  <section class="section" aria-labelledby="latest-title">
    <div class="section-heading">
      <div>
        <span class="eyebrow">Latest guides</span>
        <h2 id="latest-title">Useful guides to read first.</h2>
      </div>
      <a class="button secondary" href="/blog/">View all posts</a>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <a class="article-card" href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <span class="article-meta">{post.data.category.replace('-', ' ')}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
