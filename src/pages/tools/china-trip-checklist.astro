---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolLayout from '@layouts/ToolLayout.astro';
import PrepStatusCard from '@components/PrepStatusCard.astro';
import ChecklistBlock from '@components/ChecklistBlock.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import WarningBox from '@components/WarningBox.astro';
import OfficialSourceNote from '@components/OfficialSourceNote.astro';
import SidebarCard from '@components/SidebarCard.astro';
---

<BaseLayout
  title="China Trip Checklist"
  description="A practical China trip checklist for first-time visitors covering payment apps, internet access, hotel location, addresses, and transport planning."
  canonical="/tools/china-trip-checklist/"
>
  <ToolLayout>
    <div slot="hero" class="hub-hero">
      <div class="page-header">
        <span class="badge">Free China Travel Tool</span>
        <h1>Are You Ready to Pay and Travel in China?</h1>
        <p>Check your Alipay, WeChat Pay, international cards, backup cash, internet access, hotel address, and transport plan before you land.</p>
        <p><em>Best for first-time China visitors, Canton Fair buyers, business travelers, and sourcing trips.</em></p>
        <div class="inline-actions">
          <a class="button" href="#checklist">Start the check</a>
        </div>
        <span class="article-meta">Takes about 2 minutes</span>
      </div>
      <PrepStatusCard
        title="Payment Readiness Score"
        subtitle="Status: Not started"
        progress={0}
        tone="orange"
        items={[
          { label: 'Installed Alipay App' },
          { label: 'Linked international card' },
          { label: 'Prepared backup cash' }
        ]}
      />
    </div>

    <ChecklistBlock
      title="Payment Readiness Checklist"
      progress={0}
      interactive
      storageKey="china-trip-checklist"
      items={[
        { label: 'Installed Alipay app', description: 'Download the app before arriving in China and complete basic setup.' },
        { label: 'Installed WeChat app', description: 'Required for communication and useful as a payment backup.' },
        { label: 'Linked an international card', description: 'Add Visa, Mastercard, or JCB where supported.' },
        { label: 'Completed identity verification', description: 'Upload passport details if required by the payment app.' },
        { label: 'Tested a small payment', description: 'Try a small top-up or test transaction before relying on the app.' },
        { label: 'Prepared backup cash', description: 'Keep a small amount of RMB for emergencies.' },
        { label: 'Saved hotel address in Chinese', description: 'Useful for taxis, hotels, and payment verification situations.' },
        { label: 'Know what to do if payment fails', description: 'Prepare a backup card, cash, and support contact plan.' }
      ]}
    />

    <section class="section" aria-labelledby="backup-title">
      <h2 id="backup-title">Your Payment Backup Plan</h2>
      <div class="grid-3">
        <ToolCard icon="1" title="Primary Payment - Alipay" description="Prepare the app early, check current requirements, and test the setup before arrival." href="/blog/china-payment-apps-for-foreign-visitors/" label="Read setup guide" />
        <ToolCard icon="2" title="Backup Payment - WeChat Pay" description="Prepare as a backup for shops, restaurants, taxis, and contacts." href="/blog/china-payment-apps-for-foreign-visitors/" label="Review backup" />
        <ToolCard icon="3" title="Emergency Backup - Cash + Card" description="Carry RMB and a second card in case app payment fails." href="/china-travel/" label="Plan backup" />
      </div>
    </section>

    <section class="section" aria-labelledby="fix-title">
      <h2 id="fix-title">What to Fix Before You Land</h2>
      <div class="grid-4">
        <ToolCard compact icon="Pay" title="Set up Alipay" description="Prepare it before travel and verify current setup details in the app." href="/blog/china-payment-apps-for-foreign-visitors/" />
        <ToolCard compact icon="Chat" title="Prepare WeChat Pay" description="Useful as a second app when account support and setup are working." href="/blog/china-payment-apps-for-foreign-visitors/" />
        <ToolCard compact icon="Cash" title="Keep backup options" description="Arrange cash and second-card fallback." href="/china-travel/" />
        <ToolCard compact icon="CN" title="Save Chinese addresses" description="Hotel and destination names in Chinese characters." href="/china-travel/" />
      </div>
    </section>

    <section class="section" aria-labelledby="guides-title">
      <h2 id="guides-title">Practical Travel Setup Guides</h2>
      <div class="article-grid">
        <ArticleCard href="/blog/china-payment-apps-for-foreign-visitors/" title="1. Payment Setup" description="Prepare Alipay, WeChat Pay, backup cards, emergency cash, internet, and payment testing before arrival." category="Travel Setup" motif="checklist" />
        <ArticleCard href="/blog/china-esim-internet-access-guide/" title="2. Internet Access" description="Prepare roaming, eSIM, local SIM, Wi-Fi, app access, and a backup internet plan before arrival." category="Travel Setup" motif="map" />
        <ArticleCard href="/blog/how-to-save-use-chinese-addresses-china/" title="3. Chinese Addresses" description="Save hotel, venue, supplier, and daily destination details in Chinese before traveling." category="Travel Setup" motif="map" />
        <ArticleCard href="/blog/china-hotel-location-guide-first-time-visitors/" title="4. Hotel Location" description="Choose a practical hotel location for arrival, metro access, taxi use, food, maps, and Chinese addresses." category="Travel Setup" motif="hotel" />
        <ArticleCard href="/blog/how-to-get-around-in-china/" title="5. Getting Around" description="Plan metro, taxi, maps, ride-hailing backup, Chinese addresses, payment, and internet before arrival." category="Travel Setup" motif="map" />
        <ArticleCard href="/blog/china-travel-checklist-first-time-visitors/" title="6. Final Travel Checklist" description="Review payment, internet, hotel address, transport, daily route, and offline documents before you fly." category="Travel Setup" motif="checklist" />
      </div>
    </section>

    <OfficialSourceNote>
      This checklist is for travel preparation only. Payment app requirements and regulations may change. Always confirm the latest setup inside the official apps.
    </OfficialSourceNote>

    <SidebarCard slot="sidebar" title="Needs Attention" tone="warning">
      <p>You may still run into payment problems after landing. Fix the items below before your trip.</p>
      <ul class="recommendation-list">
        <li class="recommendation-item"><span>Set up Alipay</span><strong>!</strong></li>
        <li class="recommendation-item"><span>Prepare WeChat Pay backup</span><strong>!</strong></li>
        <li class="recommendation-item"><span>Carry RMB cash</span><strong>!</strong></li>
        <li class="recommendation-item"><span>Save addresses in Chinese</span><strong>!</strong></li>
      </ul>
    </SidebarCard>
    <WarningBox slot="sidebar" title="Travel-only checklist">
      <p>This tool is a preparation guide, not financial or legal advice. Confirm your bank and app requirements before departure.</p>
    </WarningBox>
  </ToolLayout>
</BaseLayout>
