---
interface Props {
  href: string;
  eyebrow: string;
  title: string;
  description: string;
  accent?: 'travel' | 'fair' | 'sourcing';
}

const { href, eyebrow, title, description, accent = 'travel' } = Astro.props;

const iconByAccent = {
  travel: 'TR',
  fair: 'CF',
  sourcing: 'SO'
};
---

<a class={`entry-card ${accent}`} href={href}>
  <span class="entry-icon" aria-hidden="true">{iconByAccent[accent]}</span>
  <span>{eyebrow}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <strong>Open guide</strong>
</a>
