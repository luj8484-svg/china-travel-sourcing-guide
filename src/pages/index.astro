---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import PrepStatusCard from '@components/PrepStatusCard.astro';
import PainPointCard from '@components/PainPointCard.astro';
import CategoryPathCard from '@components/CategoryPathCard.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CTASection from '@components/CTASection.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const motifByCategory = {
  'china-travel': 'map',
  'canton-fair': 'badge',
  'china-sourcing': 'supplier',
  tools: 'checklist'
} as const;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'China Buyer Prep',
    url: Astro.site?.href ?? 'https://www.chinabuyerprep.com/',
    inLanguage: 'en',
    description:
      'Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers.'
  }
];
---

<BaseLayout
  title="China Buyer Prep"
  description="Practical China travel, Canton Fair, and sourcing checklists for first-time overseas buyers."
  schema={schema}
>
  <HeroSection
    eyebrow="Updated for 2026 China travel and sourcing"
    title="Prepare for China Travel, Canton Fair, and Sourcing Trips Without Getting Stuck"
    description="Practical step-by-step guides and tools for first-time visitors, visa-free entry, Alipay, WeChat Pay, travel apps, transport, Canton Fair, Yiwu Market, Shenzhen sourcing, and supplier visits."
    primaryHref="/china-travel/"
    primaryLabel="Start the Travel Setup Checklist"
    secondaryHref="/canton-fair/"
    secondaryLabel="Explore Canton Fair Guide"
  >
    <PrepStatusCard
      slot="visual"
      progress={50}
      footer="Supplier questions prepared: 5/10"
      items={[
        { label: 'Payment Ready', status: 'Success', done: true },
        { label: 'Apps Installed', status: 'Pending' },
        { label: 'Canton Fair Plan', status: 'Ready', done: true }
      ]}
    />
  </HeroSection>

  <div class="band">
    <section class="section" aria-labelledby="pain-title">
      <div class="center-heading">
        <h2 id="pain-title">What First-Time China Visitors Usually Get Stuck On</h2>
        <p>Do not let these common roadblocks derail your trip. We map out exactly how to bypass them.</p>
      </div>
      <div class="grid-3">
        <PainPointCard icon="ID" title="Visa-Free Entry" description="Know visa policy, fill out passport qualifiers, and what documents you need to show at border control." href="/blog/china-travel-checklist-first-time-visitors/" />
        <PainPointCard icon="Pay" title="Alipay & WeChat Pay" description="Cash is rarely useful. Learn how to bind your foreign card and test payment before your trip." href="/tools/china-trip-checklist/" />
        <PainPointCard icon="App" title="Travel Apps" description="Google Maps will not work as expected. Discover essential local apps for maps, translation, and daily survival." href="/china-travel/" />
        <PainPointCard icon="Rail" title="Trains & Taxis" description="Navigate high-speed rail networks and ride-hailing with practical route planning." href="/china-travel/" />
        <PainPointCard icon="Fair" title="Canton Fair" description="Plan registration, hotel area, and a focused supplier visit strategy before arriving in Guangzhou." href="/canton-fair/" />
        <PainPointCard icon="Factory" title="Supplier Visits" description="Know what to ask, what to look for on the factory floor, and how to follow up after meetings." href="/china-sourcing/" />
      </div>
    </section>
  </div>

  <section class="section" aria-labelledby="path-title">
    <div class="center-heading">
      <h2 id="path-title">Choose Your China Prep Path</h2>
    </div>
    <div class="grid-2">
      <CategoryPathCard icon="Fly" title="First-Time China Travel" description="The complete foundation: SIM cards, VPNs, essential apps, and basic survival tips for your first arrival." href="/china-travel/" />
      <CategoryPathCard icon="Visa" title="Visa & Entry" description="Navigate the complexities of business visas, tourist visas, and the new visa-free transit policies." href="/china-travel/" label="Check requirements" />
      <CategoryPathCard icon="CF" title="Canton Fair" description="Phase schedules, buyer badge registration, pavilion maps, and tactics to efficiently source from thousands of booths." href="/canton-fair/" label="Plan your fair" />
      <CategoryPathCard icon="Buy" title="Sourcing Trip" description="Beyond the fair: visiting wholesale markets like Yiwu, auditing factories in Shenzhen, and negotiating terms." href="/china-sourcing/" label="View guides" />
    </div>
  </section>

  <div class="band">
    <section class="section" aria-labelledby="tools-title">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Practical China Trip Tools</span>
          <h2 id="tools-title">Interactive checklists and checkers to ensure you are ready.</h2>
        </div>
        <a class="button secondary" href="/tools/">View all tools</a>
      </div>
      <div class="grid-5">
        <ToolCard compact icon="Visa" title="Visa-Free Checker" description="Instantly check if your passport requires a visa." href="/tools/china-trip-checklist/" />
        <ToolCard compact icon="Pay" title="Payment Readiness" description="Step-by-step setup for Alipay and WeChat Pay." href="/tools/china-trip-checklist/" />
        <ToolCard compact icon="Apps" title="App Checklist" description="The essential apps to download before flying." href="/tools/china-trip-checklist/" />
        <ToolCard compact icon="CF" title="Canton Fair Finder" description="Find which phase your product category is in." href="/tools/canton-fair-buyer-checklist/" />
        <ToolCard compact icon="Quote" title="Question Generator" description="Create a custom supplier question list." href="/tools/supplier-comparison-sheet/" />
      </div>
    </section>
  </div>

  <section class="section" aria-labelledby="guides-title">
    <div class="center-heading">
      <h2 id="guides-title">Start With These Guides</h2>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <ArticleCard
          href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category.replace('-', ' ')}
          updated={post.data.updatedDate ? post.data.updatedDate.toLocaleDateString('en', { month: 'short', year: 'numeric' }) : post.data.pubDate.toLocaleDateString('en', { month: 'short', year: 'numeric' })}
          motif={post.data.coverMotif ?? motifByCategory[post.data.category as keyof typeof motifByCategory]}
          image={post.data.coverImage}
        />
      ))}
    </div>
  </section>

  <CTASection
    title="Get the Free China Prep Checklist"
    description="Download our comprehensive 4-week countdown checklist. We will send you exactly what to prepare and when, right to your inbox."
    buttonLabel="Send Me the Checklist"
    buttonHref="/tools/china-trip-checklist/"
  />
</BaseLayout>
