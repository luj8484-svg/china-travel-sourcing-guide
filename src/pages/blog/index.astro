---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCover from '@components/ArticleCover.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const motifByCategory = {
  'china-travel': 'map',
  'canton-fair': 'badge',
  'china-sourcing': 'supplier',
  tools: 'checklist'
} as const;
---

<BaseLayout
  title="Blog"
  description="English China travel, Canton Fair, wholesale market, and sourcing guides for international visitors and buyers."
  canonical="/blog/"
>
  <section class="content-page">
    <div class="page-header">
      <span class="eyebrow">Blog</span>
      <h1>Practical China travel and sourcing guides.</h1>
      <p>Guides for visitors, Canton Fair buyers, and small business importers preparing for China.</p>
    </div>
    <div class="article-grid">
      {posts.map((post: any) => (
        <a class="article-card" href={`/blog/${post.slug ?? post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <ArticleCover
            image={post.data.coverImage}
            alt={post.data.coverAlt ?? post.data.title}
            motif={post.data.coverMotif ?? motifByCategory[post.data.category as keyof typeof motifByCategory]}
            label={post.data.title}
            compact
          />
          <span class="article-meta">{post.data.category.replace('-', ' ')}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
