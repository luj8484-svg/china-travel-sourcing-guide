---
import BaseLayout from '@layouts/BaseLayout.astro';
import HubLayout from '@layouts/HubLayout.astro';
import HubHero from '@components/HubHero.astro';
import PainPointCard from '@components/PainPointCard.astro';
import ToolCard from '@components/ToolCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import ChecklistBlock from '@components/ChecklistBlock.astro';
import WarningBox from '@components/WarningBox.astro';
import Faq from '@components/Faq.astro';

const faqs = [
  { question: 'Which Canton Fair phase should I attend?', answer: 'Choose the phase that matches your product category before booking flights or hotels.' },
  { question: 'Where should I stay for the Canton Fair?', answer: 'Prioritize practical access to Pazhou, metro connections, and evening food options over room size alone.' },
  { question: 'Should I prepare supplier questions before the fair?', answer: 'Yes. Using the same questions at each booth makes comparison and follow-up much easier.' }
];

---

<BaseLayout
  title="Canton Fair Guide"
  description="A practical Canton Fair guide for overseas buyers covering phases, registration, hotels, booth planning, supplier questions, official detail checks, and follow-up."
  canonical="/canton-fair/"
>
  <HubLayout>
    <HubHero
      slot="hero"
      eyebrow="Canton Fair"
      title="Guide for serious first-time buyers"
      description="Confirm your phase, buyer badge, hotel area, booth strategy, supplier questions, and post-fair follow-up before you arrive in Guangzhou. Official requirements can change, so verify current details with the official Canton Fair website before booking."
      primaryHref="/tools/canton-fair-buyer-checklist/"
      primaryLabel="Open buyer checklist"
      secondaryHref="/blog/best-area-to-stay-guangzhou-canton-fair/"
      secondaryLabel="Choose hotel area"
      statusTitle="Fair Visit Readiness"
      progress={58}
    />

    <section class="section">
      <div class="center-heading">
        <h2>Who This Hub Is For</h2>
        <p>This Canton Fair guide is for overseas buyers who want the fair to produce clear supplier decisions, not just a stack of brochures.</p>
      </div>
      <div class="grid-4">
        <PainPointCard icon="P1" title="First-Time Buyers" description="Understand phases, badge setup, registration, and what to expect on fair days." />
        <PainPointCard icon="SMB" title="Small Importers" description="Build a focused visit plan that fits realistic MOQs, samples, and budgets." />
        <PainPointCard icon="B2B" title="Wholesale Buyers" description="Compare suppliers across booths using consistent questions and notes." />
        <PainPointCard icon="QC" title="Follow-Up Teams" description="Turn booth conversations into quotes, sample requests, and quality checks." />
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <h2>Start Here Before You Book</h2>
          <p>These are the decisions that shape your whole Guangzhou visit.</p>
        </div>
        <a class="button secondary" href="/blog/">View all guides</a>
      </div>
      <div class="article-grid">
        <ArticleCard href="/blog/canton-fair-buyer-badge-registration-guide/" title="Canton Fair Buyer Badge and Registration Guide for First-Time Visitors" description="Prepare registration details, badge timing, documents, confirmations, and arrival-day checks before traveling to Guangzhou." category="Canton Fair" motif="badge" />
        <ArticleCard href="/blog/supplier-questions-to-ask-at-canton-fair/" title="Supplier Questions to Ask at the Canton Fair" description="Prepare the questions that help you compare MOQ, samples, pricing, lead time, payment terms, certificates, and follow-up." category="Canton Fair" motif="supplier" />
        <ArticleCard href="/blog/canton-fair-phase-1-2-3-explained/" title="Canton Fair Phase 1, 2, and 3 Explained" description="Understand which phase matches your product category before booking flights or hotels." category="Canton Fair" motif="badge" />
        <ArticleCard href="/blog/canton-fair-first-time-buyer-guide/" title="Canton Fair Guide for First-Time Overseas Buyers" description="Phases, buyer badge basics, booth planning, supplier questions, and follow-up." category="Canton Fair" motif="badge" />
        <ArticleCard href="/blog/best-area-to-stay-guangzhou-canton-fair/" title="Best Area to Stay in Guangzhou for the Canton Fair" description="How to choose a hotel area with practical fair access and better evening logistics." category="Hotel Area" motif="hotel" />
      </div>
    </section>

    <section class="section">
      <div class="content-grid">
        <div>
          <span class="eyebrow">Canton Fair Buyer Checklist</span>
          <h2>Prepare the decisions that matter before you enter the halls.</h2>
          <p>The fair gets much easier when your phase, route, supplier notes, and follow-up questions are ready.</p>
          <div class="inline-actions">
            <a class="button" href="/tools/canton-fair-buyer-checklist/">Open buyer checklist</a>
            <a class="button secondary" href="/free-checklist/" data-track-event="checklist_cta_click" data-cta-location="canton_fair_hub" data-cta-label="Get Free Checklist" data-cta-destination="/free-checklist/">Request free checklist</a>
          </div>
        </div>
        <ChecklistBlock
          title="Fair Prep Progress"
          progress={55}
          items={[
            { label: 'Confirm product phase', description: 'Match your category to Phase 1, 2, or 3.', done: true },
            { label: 'Prepare buyer registration', description: 'Passport details, business cards, and company info.', done: true },
            { label: 'Choose hotel area', description: 'Prioritize access to Pazhou and metro routes.' },
            { label: 'Create booth note template', description: 'Record MOQ, price, samples, lead time, and contact.' },
            { label: 'Prepare supplier questions', description: 'Ask each supplier the same comparison questions.' },
            { label: 'Plan post-fair follow-up', description: 'Schedule quote, sample, and QC conversations quickly.' }
          ]}
        />
      </div>
    </section>

    <div class="band">
      <section class="section">
        <div class="center-heading">
          <h2>Related Tools</h2>
        </div>
        <div class="grid-3">
          <ToolCard icon="CF" title="Canton Fair Buyer Checklist" description="Phase, badge, hotel, booth notes, supplier questions, and follow-up." href="/tools/canton-fair-buyer-checklist/" />
          <ToolCard icon="Sheet" title="Supplier Comparison Sheet" description="Compare supplier conversations using the same fields." href="/tools/supplier-comparison-sheet/" />
          <ToolCard icon="Trip" title="China Trip Checklist" description="Prepare payment, internet, transport, and Chinese addresses." href="/tools/china-trip-checklist/" />
        </div>
      </section>
    </div>

    <section class="section">
      <div class="center-heading">
        <h2>Common Canton Fair Mistakes</h2>
      </div>
      <div class="grid-3">
        <WarningBox title="Booking Before Checking Phase"><p>Flights and hotels should follow the correct product phase, not the other way around.</p></WarningBox>
        <WarningBox title="Collecting Brochures Without Notes"><p>Supplier details blur together quickly. Write structured notes after every meaningful booth visit.</p></WarningBox>
        <WarningBox title="Waiting Too Long To Follow Up"><p>Request quotes and samples while conversations are still fresh.</p></WarningBox>
      </div>
      <Faq title="Canton Fair FAQs" items={faqs} />
    </section>
  </HubLayout>
</BaseLayout>
