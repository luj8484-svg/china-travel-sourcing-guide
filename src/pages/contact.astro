---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact China Travel & Sourcing Guide for China trip planning, Canton Fair questions, or sourcing service inquiries."
  canonical="/contact/"
>
  <section class="content-page">
    <div class="page-header">
      <span class="eyebrow">Contact</span>
      <h1>Ask a China travel or sourcing question.</h1>
      <p>
        Replace the email below with your business inbox later, or connect this page to a form service such as Tally,
        Formspree, or a CRM lead form.
      </p>
    </div>
    <div class="content-grid">
      <div class="prose">
        <h2>What to include</h2>
        <ul>
          <li>Your destination or trade fair dates</li>
          <li>Your product category or sourcing goal</li>
          <li>Your timeline, budget range, and preferred language</li>
          <li>Whether you need a checklist, consultation, or supplier support</li>
        </ul>
      </div>
      <aside class="sidebar">
        <div class="notice-box">
          <h2>Email</h2>
          <p><a href="mailto:hello@chinatravelsourcingguide.com">hello@chinatravelsourcingguide.com</a></p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
