---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FaqItem[];
  title?: string;
}

const { items = [], title = 'FAQ' } = Astro.props;
---

{items.length > 0 && (
  <section class="faq-block" aria-labelledby="faq-title">
    <h2 id="faq-title">{title}</h2>
    <div class="faq-list">
      {items.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
